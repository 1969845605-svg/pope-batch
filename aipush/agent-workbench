<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Push Optimization Workbench</title>
    <style>
      :root {
        --bg: #f5f7fb;
        --panel: #ffffff;
        --line: #d9e0ea;
        --text: #15202b;
        --muted: #6b7785;
        --accent: #1f6feb;
        --accent-light: #eef5ff;
        --success: #2da44e;
        --success-light: #f0fff4;
        --warning: #d4a72c;
        --radius: 8px;
        --left-width: 320px;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font: 13px/1.5 -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
      }

      .app {
        display: grid;
        grid-template-columns: var(--left-width) 1fr 260px;
        min-height: 100vh;
      }

      .panel-resizer {
        width: 4px;
        cursor: col-resize;
        background: var(--line);
        transition: background 0.15s;
        display: none;
      }

      .panel-resizer:hover,
      .panel-resizer.dragging {
        background: var(--accent);
      }

      .panel-resizer::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 2px;
        height: 30px;
        background: var(--muted);
        border-radius: 2px;
        opacity: 0.5;
      }

      .panel-resizer:hover::after,
      .panel-resizer.dragging::after {
        background: var(--accent);
        opacity: 1;
      }

      .panel {
        background: var(--panel);
        border: 1px solid var(--line);
        overflow-y: auto;
        max-height: 100vh;
      }

      .panel-header {
        padding: 12px 14px;
        border-bottom: 1px solid var(--line);
        font-weight: 600;
        font-size: 12px;
        color: var(--muted);
        position: sticky;
        top: 0;
        background: var(--panel);
        z-index: 1;
      }

      .panel-body { padding: 14px; }

      .field { margin-bottom: 12px; }
      .field label {
        display: block;
        font-size: 12px;
        color: var(--text);
        margin-bottom: 6px;
        font-weight: 600;
      }

      textarea, input, select {
        width: 100%;
        padding: 8px 10px;
        border: 1px solid var(--line);
        border-radius: 6px;
        font: inherit;
        font-size: 12px;
        background: #fff;
      }

      textarea { resize: none; min-height: 40px; overflow-y: auto; }
      #base-prompt { min-height: 280px; }
      #strategy { min-height: 80px; }
      input[type="number"] { width: 70px; }

      /* Dynamic Parameters */
      .param-section {
        margin-top: 8px;
        padding: 10px;
        background: var(--bg);
        border-radius: 6px;
        border: 1px solid var(--line);
      }

      .param-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 8px;
      }

      .param-section-title {
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
      }

      .param-count {
        font-size: 10px;
        padding: 2px 6px;
        background: var(--accent);
        color: #fff;
        border-radius: 4px;
      }

      .param-item {
        margin-bottom: 8px;
      }

      .param-item:last-child { margin-bottom: 0; }

      .param-item label {
        display: block;
        font-size: 11px;
        font-weight: 500;
        margin-bottom: 4px;
        color: var(--text);
      }

      .param-item label .param-name {
        background: var(--accent-light);
        color: var(--accent);
        padding: 2px 6px;
        border-radius: 4px;
        font-family: ui-monospace, monospace;
        font-size: 10px;
      }

      .param-item input {
        width: 100%;
        padding: 6px 8px;
        font-size: 11px;
        border: 1px solid var(--line);
        border-radius: 4px;
      }

      /* Tree View */
      .tree-view {
        margin-top: 12px;
      }

      .tree-level-1 {
        margin-bottom: 12px;
      }

      .tree-prompt-card {
        border: 1px solid var(--line);
        border-radius: 6px;
        overflow: hidden;
      }

      .tree-prompt-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 10px;
        background: var(--bg);
        border-bottom: 1px solid var(--line);
        cursor: pointer;
      }

      .tree-prompt-header:hover { background: var(--line); }

      .tree-connector {
        width: 12px;
        height: 12px;
        border-left: 2px solid var(--line);
        border-bottom: 2px solid var(--line);
        display: inline-block;
        transform: rotate(-45deg);
        transition: transform 0.2s;
      }

      .tree-prompt-card.open .tree-connector { transform: rotate(45deg); }

      .tree-strategy-name {
        font-weight: 600;
        font-size: 12px;
      }

      .tree-strategy-badge {
        font-size: 10px;
        padding: 2px 6px;
        background: var(--success);
        color: #fff;
        border-radius: 4px;
        margin-left: auto;
      }

      .tree-push-list {
        display: none;
        padding: 8px;
        gap: 6px;
      }

      .tree-prompt-card.open .tree-push-list { display: flex; flex-direction: column; }

      .tree-push-item {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 8px 10px;
        background: var(--bg);
        border-radius: 6px;
        border: 1px solid transparent;
        font-size: 11px;
      }

      .tree-push-item:hover { border-color: var(--accent); }
      .tree-push-item.best {
        background: var(--success-light);
        border-color: var(--success);
      }

      .tree-push-rank {
        font-weight: 700;
        color: var(--muted);
        min-width: 20px;
      }

      .tree-push-item.best .tree-push-rank { color: var(--success); }

      .tree-push-content { flex: 1; min-width: 0; }

      .tree-push-text {
        line-height: 1.4;
        word-break: break-word;
      }

      .tree-push-metrics {
        display: flex;
        gap: 8px;
        margin-top: 4px;
        font-size: 10px;
        color: var(--muted);
      }

      .tree-push-score {
        font-weight: 700;
        font-size: 14px;
        color: var(--success);
        white-space: nowrap;
        text-align: right;
        min-width: 40px;
      }

      .tree-push-item.best .tree-push-score { font-size: 16px; }

      .tree-score-bar {
        width: 100%;
        height: 3px;
        background: var(--line);
        border-radius: 2px;
        margin-top: 4px;
        overflow: hidden;
      }

      .tree-score-fill {
        height: 100%;
        background: var(--accent);
        border-radius: 2px;
        transition: width 0.3s;
      }

      .tree-push-item.best .tree-score-fill { background: var(--success); }

      .section-title {
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
        margin: 14px 0 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

.section-title:first-child { margin-top: 0; }

      .weights-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 8px;
      }

      .weight-row {
        display: flex;
        gap: 8px;
        margin-bottom: 8px;
      }

      .weight-row .weight-item {
        flex: 1;
        min-width: 0;
      }

      .weight-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 6px;
        font-size: 11px;
        background: var(--bg);
        padding: 6px 10px;
        border-radius: 6px;
        border: 1px solid var(--line);
      }

      .weight-item-name {
        font-weight: 500;
        font-size: 11px;
        flex-shrink: 0;
      }

      .weight-item-value {
        display: flex;
        align-items: center;
        gap: 4px;
      }

      .weight-item-value input {
        width: 50px;
        padding: 3px 5px;
        text-align: center;
        border: 1px solid var(--line);
        border-radius: 4px;
        font-size: 10px;
        background: #fff;
        flex-shrink: 0;
      }

      .weight-sum {
        display: flex;
        justify-content: flex-end;
        font-size: 11px;
      }

      .weight-sum.ok { color: var(--success); }

      .status {
        margin-top: 10px;
        padding: 8px;
        background: var(--bg);
        border-radius: 6px;
        font-size: 11px;
        color: var(--muted);
      }

      /* Main Panel */
      .main-panel { border-left: none; border-right: none; }

      .round-card {
        border: 1px solid var(--line);
        border-radius: var(--radius);
        margin-bottom: 12px;
        background: #fff;
        overflow: hidden;
      }

      .round-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 12px;
        background: var(--bg);
        border-bottom: 1px solid var(--line);
      }

      .round-number {
        font-weight: 600;
        font-size: 12px;
      }

      .round-badge {
        font-size: 10px;
        padding: 2px 6px;
        background: var(--accent);
        color: #fff;
        border-radius: 4px;
      }

      .round-body { padding: 12px; }

      .round-expand-btn {
        width: 100%;
        padding: 6px;
        background: var(--bg);
        border: 1px solid var(--line);
        border-radius: 4px;
        cursor: pointer;
        font-size: 11px;
        color: var(--muted);
        margin-top: 10px;
      }
      .round-expand-btn:hover { background: var(--line); }

      .btn {
        padding: 10px 16px;
        border: none;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
        cursor: pointer;
        width: 100%;
        margin-bottom: 10px;
      }

      .btn-primary { background: var(--accent); color: #fff; }
      .btn:hover { opacity: 0.85; }

      .round-content { display: none; }
      .round-content.open { display: block; }

      .expand-section {
        margin-top: 12px;
        border-top: 1px solid var(--line);
        padding-top: 12px;
      }

      .expand-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        padding: 6px 0;
      }

      .expand-section-header:hover { color: var(--accent); }

      .expand-section-title {
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
      }

      .expand-section-content { display: none; margin-top: 8px; }
      .expand-section-content.open { display: block; }

      .topk-badge {
        font-size: 9px;
        padding: 1px 4px;
        background: var(--success);
        color: #fff;
        border-radius: 3px;
        margin-left: 4px;
      }

      /* Prompt Card (compact) */
      .prompt-mini-card {
        border: 1px solid var(--line);
        border-radius: 6px;
        padding: 8px 10px;
        margin-bottom: 6px;
        cursor: pointer;
        transition: all 0.15s;
      }

      .prompt-mini-card:hover { border-color: var(--accent); }
      .prompt-mini-card.topk {
        border-color: var(--success);
        background: var(--success-light);
      }

      .prompt-mini-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 4px;
      }

      .prompt-id { font-weight: 600; font-size: 11px; }
      .prompt-score { font-size: 14px; font-weight: 700; color: var(--success); }

      .prompt-preview {
        font-size: 11px;
        color: var(--muted);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      /* Push Group */
      .push-group {
        margin-bottom: 10px;
      }

      .push-group-title {
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
        margin-bottom: 4px;
      }

      /* Score Table */
      .score-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 11px;
      }

      .score-table th {
        text-align: left;
        padding: 6px 8px;
        background: var(--bg);
        border-bottom: 1px solid var(--line);
        font-weight: 600;
        color: var(--muted);
      }

      .score-table td {
        padding: 6px 8px;
        border-bottom: 1px solid var(--line);
      }

      .score-table tr:hover td { background: var(--accent-light); }

      /* Right Panel - Metrics */
      .metric-card {
        border: 1px solid var(--line);
        border-radius: 6px;
        padding: 10px;
        margin-bottom: 10px;
        background: #fff;
      }

      .metric-title {
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
        margin-bottom: 8px;
      }

      .metric-value {
        font-size: 20px;
        font-weight: 700;
        color: var(--success);
      }

      .metric-label { font-size: 10px; color: var(--muted); margin-top: 2px; }

      .best-push-preview {
        font-size: 12px;
        line-height: 1.5;
        padding: 8px;
        background: var(--success-light);
        border-radius: 4px;
        margin-top: 6px;
      }

      /* History List */
      .history-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 10px;
        border: 1px solid var(--line);
        border-radius: 6px;
        margin-bottom: 6px;
        cursor: pointer;
        background: #fff;
        width: 100%;
        text-align: left;
        font: inherit;
      }
      .history-item:hover { border-color: var(--accent); }
      .history-item.active { border-color: var(--accent); background: var(--accent-light); }
      .history-item.best { border-color: var(--success); background: var(--success-light); }

      .history-round { font-weight: 600; font-size: 11px; }
      .history-score { font-weight: 700; color: var(--success); font-size: 12px; }

      /* Mini Chart */
      .mini-chart {
        display: flex;
        align-items: flex-end;
        gap: 3px;
        height: 50px;
        padding: 4px 0;
      }

      .chart-bar {
        flex: 1;
        background: var(--accent);
        border-radius: 2px;
        min-height: 4px;
        transition: height 0.3s;
      }

      .chart-bar.best { background: var(--success); }

      /* API Console */
      .api-console {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: var(--panel);
        border-top: 1px solid var(--line);
        z-index: 100;
      }

      .api-toggle {
        width: 100%;
        padding: 8px 14px;
        background: var(--panel);
        border: none;
        border-top: 1px solid var(--line);
        cursor: pointer;
        font: inherit;
        font-size: 12px;
        font-weight: 500;
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: var(--muted);
      }

      .api-content {
        display: none;
        max-height: 200px;
        overflow-y: auto;
        padding: 10px 14px;
        font-family: ui-monospace, Consolas, monospace;
        font-size: 11px;
        line-height: 1.8;
      }

      .api-content.open { display: block; }

      .log-entry { color: var(--muted); }
      .log-entry.success { color: var(--success); }
      .log-entry.error { color: #c41; }
      .log-entry .time { color: var(--muted); opacity: 0.6; }

      /* Hover Tooltip */
      .tooltip {
        position: fixed;
        max-width: 300px;
        padding: 10px 12px;
        background: var(--text);
        color: #fff;
        border-radius: 6px;
        font-size: 11px;
        line-height: 1.5;
        z-index: 1000;
        pointer-events: none;
        display: none;
        white-space: pre-wrap;
      }

      .tooltip.show { display: block; }

      /* Push Detail Modal */
      .push-modal {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: none;
        align-items: center;
        justify-content: center;
      }

      .push-modal.open {
        display: flex;
      }

      .push-modal-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
      }

      .push-modal-content {
        position: relative;
        background: #fff;
        border-radius: 12px;
        padding: 20px;
        max-width: 500px;
        width: 90%;
        max-height: 80vh;
        overflow-y: auto;
        box-shadow: 0 8px 32px rgba(0,0,0,0.2);
      }

      .modal-push-text {
        font-size: 14px;
        line-height: 1.6;
        margin-bottom: 16px;
        padding: 12px;
        background: var(--bg);
        border-radius: 8px;
      }

      .modal-push-score {
        font-size: 18px;
        font-weight: 700;
        color: var(--success);
        margin-bottom: 16px;
      }

      .modal-push-metrics {
        display: grid;
        gap: 8px;
      }

      .modal-metric {
        display: flex;
        justify-content: space-between;
        padding: 8px 12px;
        background: var(--bg);
        border-radius: 6px;
        font-size: 12px;
      }

      .modal-metric span:first-child {
        color: var(--muted);
      }

      .modal-metric span:last-child {
        font-weight: 600;
      }

      /* Empty State */
      .empty {
        padding: 20px;
        text-align: center;
        color: var(--muted);
        border: 1px dashed var(--line);
        border-radius: 8px;
        font-size: 11px;
      }

      /* Timeline View */
      .timeline-container {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .timeline-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 0;
        border-bottom: 1px solid var(--line);
        margin-bottom: 4px;
      }

      .timeline-round-label {
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
        font-size: 12px;
      }

      .timeline-round-label.current {
        color: var(--accent);
      }

      .timeline-round-label .score {
        font-weight: 700;
        color: var(--success);
      }

      .timeline-arrow {
        color: var(--muted);
        font-size: 16px;
      }

      .timeline-row {
        display: flex;
        align-items: flex-start;
        gap: 8px;
      }

      .timeline-round-column {
        display: flex;
        flex-direction: column;
        gap: 6px;
        width: 130px;
        min-width: 130px;
      }

      .timeline-connector {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 4px;
        min-width: 50px;
        color: var(--muted);
        font-size: 11px;
      }

      .prompt-card-timeline {
        border: 1px solid var(--line);
        border-radius: 6px;
        padding: 8px;
        background: #fff;
        cursor: pointer;
        transition: all 0.15s;
      }

      .prompt-card-timeline:hover {
        border-color: var(--accent);
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      }

      .prompt-card-timeline.topk {
        border-color: var(--success);
        background: var(--success-light);
      }

      .prompt-card-timeline-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 4px;
      }

      .prompt-card-timeline-name {
        font-weight: 600;
        font-size: 11px;
      }

      .prompt-card-timeline-score {
        font-weight: 700;
        font-size: 13px;
        color: var(--success);
      }

      .prompt-card-timeline-preview {
        font-size: 10px;
        color: var(--muted);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .timeline-summary {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 8px;
        padding: 10px;
        background: var(--success-light);
        border: 1px solid var(--success);
        border-radius: 6px;
        font-size: 12px;
      }

      .timeline-summary-icon {
        font-size: 16px;
      }

      .timeline-summary-text {
        flex: 1;
      }

      .timeline-summary-score {
        font-weight: 700;
        color: var(--success);
        font-size: 16px;
      }

      /* Prompt Tree View */
      .round-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      .round-section {
        border: 1px solid var(--line);
        border-radius: 8px;
        overflow: hidden;
      }

      .round-section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 12px 14px;
        background: var(--bg);
        border-bottom: 1px solid var(--line);
      }

      .round-title {
        font-weight: 600;
        font-size: 13px;
      }

      .round-best {
        font-weight: 700;
        color: var(--success);
        font-size: 13px;
      }

      .prompt-tree {
        border-bottom: 1px solid var(--line);
      }

      .prompt-tree:last-child {
        border-bottom: none;
      }

      .prompt-tree.best {
        background: var(--success-light);
      }

      .prompt-tree-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        cursor: pointer;
        transition: background 0.15s;
      }

      .prompt-tree-header:hover {
        background: var(--bg);
      }

      .prompt-tree-toggle {
        font-size: 10px;
        color: var(--muted);
        width: 16px;
      }

      .prompt-tree-name {
        font-weight: 600;
        font-size: 12px;
      }

      .prompt-tree-score {
        font-weight: 700;
        color: var(--success);
      }

      .prompt-tree-header .optimize-btn {
        padding: 4px 10px;
        font-size: 11px;
        margin-left: auto;
      }

      .prompt-tree-header .optimize-btn:first-of-type {
        margin-right: 4px;
      }

      .prompt-tree-star {
        font-size: 12px;
      }

      .prompt-tree-top {
        font-size: 9px;
        padding: 2px 6px;
        background: var(--success);
        color: #fff;
        border-radius: 4px;
        margin-left: 4px;
      }

      .prompt-tree-content {
        padding: 0 14px 12px 38px;
      }

      .push-item {
        padding: 6px 0;
        font-size: 11px;
        border-bottom: 1px dashed var(--line);
        cursor: pointer;
      }

      .push-item:last-child {
        border-bottom: none;
      }

      .push-item:hover {

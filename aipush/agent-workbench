        .timeline-row { flex-direction: column; }
        .timeline-round-column { width: 100%; flex-direction: row; flex-wrap: wrap; }
        .timeline-connector { display: none; }
      }
    </style>
  </head>
  <body>
    <div class="app">
      <!-- LEFT PANEL: Control Panel -->
      <aside class="panel left">
        <div class="panel-header">Control Panel</div>
        <div class="panel-body">
          <div class="field">
            <label>Base Prompt</label>
            <textarea id="base-prompt"></textarea>
          </div>

          <div id="param-section" class="param-section">
            <div class="param-section-header">
              <span class="param-section-title">Parameters</span>
              <span class="param-count" id="param-count">0</span>
            </div>
            <div id="param-fields"></div>
          </div>

          <div class="field">
            <label>Prompt Rewrite Rules</label>
            <textarea id="strategy"></textarea>
          </div>

          <div class="field">
            <label>Judge Weights</label>
            <div class="weights-list" id="weights-list">
              <div class="weight-row">
                <div class="weight-item">
                  <div class="weight-item-name">Clarity</div>
                  <div class="weight-item-value">
                    <input type="number" value="0.25" step="0.05" min="0" max="1" class="weight-input" data-index="0" />
                  </div>
                </div>
                <div class="weight-item">
                  <div class="weight-item-name">Tone</div>
                  <div class="weight-item-value">
                    <input type="number" value="0.25" step="0.05" min="0" max="1" class="weight-input" data-index="1" />
                  </div>
                </div>
              </div>
              <div class="weight-row">
                <div class="weight-item">
                  <div class="weight-item-name">CTR</div>
                  <div class="weight-item-value">
                    <input type="number" value="0.25" step="0.05" min="0" max="1" class="weight-input" data-index="2" />
                  </div>
                </div>
                <div class="weight-item">
                  <div class="weight-item-name">Compliance</div>
                  <div class="weight-item-value">
                    <input type="number" value="0.25" step="0.05" min="0" max="1" class="weight-input" data-index="3" />
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="field">
            <label>API Settings</label>
            <input type="password" id="api-key" placeholder="Enter API Key..." style="margin-bottom:8px;" />
            <select id="model-select" style="width:100%;padding:6px 8px;font-size:11px;border:1px solid var(--line);border-radius:4px;margin-bottom:8px;">
              <option value="MiniMax-M2.7">MiniMax-M2.7</option>
              <option value="MiniMax-M2.7-highspeed">MiniMax-M2.7-highspeed</option>
              <option value="MiniMax-M2.5">MiniMax-M2.5</option>
              <option value="MiniMax-M2.5-highspeed">MiniMax-M2.5-highspeed</option>
              <option value="MiniMax-M2">MiniMax-M2</option>
            </select>
            <input type="text" id="api-endpoint" value="https://api.minimaxi.com/v1/text/chatcompletion_v2" placeholder="API Endpoint" style="font-size:11px;" />
          </div>

          <div id="log-entries" style="margin-top:12px;padding:8px;background:var(--bg);border-radius:6px;font-size:11px;max-height:120px;overflow-y:auto;"></div>

          <div style="margin-top:14px;">
            <button class="btn btn-primary" id="run-round-btn">Run Next Round</button>
            <button class="btn" id="reset-btn">Reset</button>
          </div>

          <div class="status" id="status">Click "Run Next Round" to start</div>
        </div>
      </aside>

      <!-- CENTER PANEL: Evolution Board -->
      <main class="panel main-panel">
        <div class="panel-header">Evolution Board <span id="round-count" style="font-weight:normal;margin-left:8px;"></span></div>
        <div class="panel-body" id="evolution-board">
          <div class="empty">No runs yet. Click "Run Next Round" on the left to start.</div>
        </div>
      </main>

      <!-- RIGHT PANEL: History -->
      <aside class="panel right">
        <div class="panel-header">History</div>
        <div class="panel-body">
          <div id="history-list">
            <div class="empty">No history</div>
          </div>
        </div>
      </aside>
    </div>

    <!-- Tooltip -->
    <div class="tooltip" id="tooltip"></div>

    <!-- Push Detail Modal -->
    <div class="push-modal" id="push-modal">
      <div class="push-modal-overlay" onclick="hidePushDetail()"></div>
      <div class="push-modal-content" id="push-modal-content">
      </div>
    </div>

    <script>
      const STORAGE_KEY = "ai_push_evolution_v2";

      const state = {
        basePrompt: "",
        strategy: "",
        params: {},
        promptCount: 3,
        pushCount: 3,
        topK: 1,
        weights: [
          { name: "Clarity", value: 0.25 },
          { name: "Tone", value: 0.25 },
          { name: "CTR", value: 0.25 },
          { name: "Compliance", value: 0.25 }
        ],
        runtime: {
          apiKey: "",
          model: "MiniMax-M2.7",
          endpoint: "https://api.minimaxi.com/v1/text/chatcompletion_v2"
        },
        rounds: [],
        globalBest: null,
        currentRound: 0,
        viewingRoundNum: null,
        logs: []
      };

      const $ = id => document.getElementById(id);

      function deepClone(obj) { return JSON.parse(JSON.stringify(obj)); }

      function generateId() { return Math.random().toString(36).slice(2, 8); }

      function log(msg, type = "") {
        const time = new Date().toLocaleTimeString();
        state.logs.push({ time, msg, type });
        renderLogs();
      }

      function renderLogs() {
        const el = $("log-entries");
        if (!el) return;
        el.innerHTML = state.logs.map(l => `
          <div class="log-entry ${l.type}"><span class="time">[${l.time}]</span> ${l.msg}</div>
        `).join("");
        el.scrollTop = el.scrollHeight;
      }

      function saveState() {
        const toSave = {
          rounds: state.rounds,
          basePrompt: state.basePrompt,
          strategy: state.strategy,
          params: state.params,
          currentRound: state.currentRound,
          globalBest: state.globalBest,
          viewingRoundNum: state.viewingRoundNum
        };
        localStorage.setItem(STORAGE_KEY, JSON.stringify(toSave));
      }

      function loadState() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          if (raw) {
            const saved = JSON.parse(raw);
            state.rounds = saved.rounds || [];
            state.basePrompt = saved.basePrompt || '';
            state.strategy = saved.strategy || '';
            state.params = saved.params || {};
            state.currentRound = saved.currentRound || 0;
            state.globalBest = saved.globalBest || null;
            state.viewingRoundNum = saved.viewingRoundNum || null;

            $("base-prompt").value = state.basePrompt;
            $("strategy").value = state.strategy;
            autoResizeTextarea($("base-prompt"));
            autoResizeTextarea($("strategy"));
            renderParamFields();
          }
        } catch {
          state.rounds = [];
        }
      }

      async function callMiniMax(systemPrompt, userPrompt) {
        const response = await fetch(state.runtime.endpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${state.runtime.apiKey}`
          },
          body: JSON.stringify({
            model: state.runtime.model,
            messages: [
              { role: "system", content: systemPrompt },
              { role: "user", content: userPrompt }
            ]
          })
        });
        const raw = await response.text();
        if (!response.ok) throw new Error(`HTTP ${response.status}: ${raw}`);
        const data = JSON.parse(raw);
        return data.choices?.[0]?.message?.content || "";
      }

      function updateWeightSum() {
        const inputs = document.querySelectorAll(".weight-input");
        let sum = 0;
        inputs.forEach((input, i) => {
          state.weights[i].value = parseFloat(input.value) || 0;
          sum += state.weights[i].value;
        });
        const sumEl = $("weight-sum");
        if (Math.abs(sum - 1) < 0.001) {
          sumEl.innerHTML = `Sum: ${sum.toFixed(2)} ✓`;
          sumEl.className = "weight-sum ok";
        } else {
          sumEl.innerHTML = `Sum: ${sum.toFixed(2)} (should be 1.00)`;
          sumEl.className = "weight-sum";
          sumEl.style.color = "#c41";
        }
      }

      function extractParams(text) {
        const matches = text.match(/\{\{([^}]+)\}\}/g) || [];
        return [...new Set(matches.map(m => m.slice(2, -2)))];
      }

      function resolvePrompt(text, params) {
        let resolved = text;
        Object.entries(params).forEach(([key, value]) => {
          const escapedKey = key.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
          resolved = resolved.replace(new RegExp(`\\{\\{${escapedKey}\\}\\}`, "g"), value || `{{${key}}}`);
        });
        return resolved;
      }

      function renderParamFields() {
        const params = extractParams(state.basePrompt);
        const section = $("param-section");
        const fieldsContainer = $("param-fields");
        const countBadge = $("param-count");

        if (params.length === 0) {
          section.style.display = "none";
          return;
        }

        section.style.display = "block";
        countBadge.textContent = params.length;

        params.forEach(p => {
          if (!state.params.hasOwnProperty(p)) {
            state.params[p] = "";
          }
        });

        Object.keys(state.params).forEach(key => {
          if (!params.includes(key)) {
            delete state.params[key];
          }
        });

        fieldsContainer.innerHTML = params.map(p => {
          const safeId = 'param-' + p.replace(/[^a-zA-Z0-9]/g, '_');
          const escapedP = p.replace(/'/g, "\\'");
          return `
          <div class="param-item">
            <label><span class="param-name">{{${p}}}</span></label>
            <input type="text" id="${safeId}" value="${(state.params[p] || "").replace(/"/g, "&quot;")}"
                   placeholder="Enter ${p}..." onchange="updateParam('${escapedP}', this.value)" />
          </div>
        `;
        }).join("");
      }

      function updateParam(key, value) {
        state.params[key] = value;
        renderParamFields();
      }

      // Generate Round Data
      function generateRound(roundNum, parentPrompts = []) {
        const resolvedPrompt = resolvePrompt(state.basePrompt, state.params);
        const prompts = [];

        // Generate prompts (parent prompts continue, otherwise create new ones)
        const promptCount = parentPrompts.length > 0 ? Math.min(parentPrompts.length, state.promptCount) : state.promptCount;

        for (let p = 0; p < promptCount; p++) {
          const parentPrompt = parentPrompts[p];
          const promptText = parentPrompt
            ? parentPrompt.text + " [Iteration]"
            : resolvedPrompt;

          const pushes = [];

          // Each prompt generates pushCount pushes
          for (let i = 0; i < state.pushCount; i++) {
            const baseScore = 70 + Math.random() * 20;
            const score = Math.round(baseScore * 10) / 10;
            const metrics = {
              "Clarity": Math.round(score * (0.9 + Math.random() * 0.2)),
              "Tone": Math.round(score * (0.9 + Math.random() * 0.2)),
              "CTR": Math.round(score * (0.9 + Math.random() * 0.2)),
              "Compliance": Math.round(score * (0.9 + Math.random() * 0.2))
            };
            pushes.push({
              id: `push-${generateId()}`,
              text: `${promptText} (${i + 1})`,
              score,
              metrics
            });
          }

          // Sort pushes by score
          pushes.sort((a, b) => b.score - a.score);

          // Prompt score = best push score
          const promptScore = pushes[0].score;

          prompts.push({
            id: `prompt-${generateId()}`,
            text: promptText,
            score: promptScore,
            pushes: pushes,
            bestPush: pushes[0],
            parentId: parentPrompt ? parentPrompt.id : null
          });
        }

        // Sort prompts by score
        prompts.sort((a, b) => b.score - a.score);

        const topKPrompts = prompts.slice(0, state.topK);
        const bestPrompt = topKPrompts[0];
        const bestPush = bestPrompt ? bestPrompt.bestPush : null;

        return {
          roundNum,
          prompts,
          topKPrompts,
          bestPrompt,
          bestPush
        };
      }

      async function runNextRound() {
        if (!state.runtime.apiKey) {
          alert("请先填写 API Key");
          return;
        }

        if (!state.basePrompt.trim()) {
          alert("请先填写 Base Prompt");
          return;
        }

        state.currentRound++;
        log(`[Round ${state.currentRound}] Starting...`, "");

        const parentPrompts = state.rounds.length > 0
          ? state.rounds[state.rounds.length - 1].topKPrompts
          : [];

        try {
          const w0 = state.weights[0]?.value || 0.25;
          const w1 = state.weights[1]?.value || 0.25;
          const w2 = state.weights[2]?.value || 0.25;
          const w3 = state.weights[3]?.value || 0.25;

          log(`[Step 1] Generating 3 prompts × 3 pushes with scores...`, "");

          const apiRequest = `[Pasted]输出 JSON，不要任何额外解释。

结构：
{
  "variants": [
    {
      "prompt": "第一条 prompt 的完整内容",
      "pushes": [
        {
          "title": "标题1",
          "body": "正文1",
          "score": {
            "Clarity": 0,
            "Tone": 0,
            "CTR": 0,
            "Compliance": 0,
            "total": 0
          }
        },
        {
          "title": "标题2",
          "body": "正文2",
          "score": { ... }
        },
        {
          "title": "标题3",
          "body": "正文3",
          "score": { ... }
        }
      ]
    },
    {
      "prompt": "第二条 prompt 的完整内容",
      "pushes": [ ... ]
    },
    {
      "prompt": "第三条 prompt 的完整内容",
      "pushes": [ ... ]
    }
  ]
}

Base Prompt:
${state.basePrompt}

Rewrite Rules:
${state.strategy || "无"}

要求：
1. 基于 Base Prompt 进行微调，生成3个不同的 prompt 变体
2. 【重要】保留 Base Prompt 的全部内容，只在开头、中间或结尾添加少量规则和说明
3. 【禁止】不要删除、替换或大幅修改 Base Prompt 的原有内容
4. 【禁止】不要删除原有的占位符（如 {{userName}} 等），保持原样
5. 每个 prompt 生成3个 push
6. 对每个 push 进行评分（每个维度 1–100 分，整数）：
   - Clarity: 信息清晰度（金额、动作、有效期是否一目了然）
   - Tone: 语气是否自然、人性化、不公司腔
   - CTR: 点击潜力（利益点 + 行动指令）
   - Compliance: 合规性（无敏感词、无虚假、无违规）
   - total = Clarity×${w0} + Tone×${w1} + CTR×${w2} + Compliance×${w3}
7. 所有分数按上述规则计算后填入每个 push 的 score 对象。`;

          const apiResponse = await callMiniMax(
            "You are an AI Push optimization assistant. Return ONLY valid JSON with no additional text.",
            apiRequest
          );

          let variants = [];
          try {
            let jsonStr = apiResponse;
            const match = apiResponse.match(/```(?:json)?\s*([\s\S]*?)```/);
            if (match && match[1]) {
              jsonStr = match[1];
            }
            const parsed = JSON.parse(jsonStr.trim());
            variants = parsed.variants || [];
          } catch (e) {
            log(`[Error] Failed to parse API response: ${e.message}`, "error");
            log(`[Raw Response] ${apiResponse.slice(0, 200)}...`, "error");
            return;
          }

          if (variants.length < 3) {
            log(`[Warning] Only ${variants.length} variants returned, expected 3`, "error");
          }

          log(`[Step 1] Generated ${variants.length} variants`, "success");

          const promptsWithPushes = variants.slice(0, 3).map((variant, pi) => {
            const pushes = (variant.pushes || []).slice(0, 3).map((p, i) => ({
              id: `push-${generateId()}`,
              text: `${p.title || ''} ${p.body || ''}`.trim(),
              title: p.title || '',
              body: p.body || '',
              score: typeof p.score?.total === 'number' ? p.score.total : 0,
              metrics: {
                "Clarity": p.score?.Clarity || 0,
                "Tone": p.score?.Tone || 0,
                "CTR": p.score?.CTR || 0,
                "Compliance": p.score?.Compliance || 0
              }
            }));

            pushes.sort((a, b) => b.score - a.score);

            log(`[Variant ${pi + 1}] Best push score: ${pushes[0]?.score || 'N/A'}`, "success");

            return {
              id: `prompt-${generateId()}`,
              text: variant.prompt || '',
              pushes: pushes,
              bestPush: pushes[0]
            };
          });

          promptsWithPushes.sort((a, b) => (b.bestPush?.score || 0) - (a.bestPush?.score || 0));

          // Sort prompts by their best push score
          promptsWithPushes.sort((a, b) => (b.bestPush?.score || 0) - (a.bestPush?.score || 0));

          const newRound = {
            roundNum: state.currentRound,
            prompts: promptsWithPushes,
            topKPrompts: promptsWithPushes,
            bestPrompt: promptsWithPushes[0],
            bestPush: promptsWithPushes[0]?.bestPush || null,
            pendingSelection: true
          };

          state.rounds.push(newRound);

          // Show selection UI
          renderEvolutionBoard();
          $("status").textContent = `Round ${state.currentRound}: 请选择最佳 Push`;

          log(`[System] Please select the best push from the 3 options above`, "");

        } catch (error) {
          log(`[Error] ${error.message}`, "error");
          $("status").textContent = `Error: ${error.message}`;
        }
      }

      function selectPush(promptIndex, pushId) {
        const round = state.rounds[state.rounds.length - 1];
        if (!round || !round.pendingSelection) return;
        if (!round.prompts || !round.prompts[promptIndex]) return;

        const selectedPush = round.prompts[promptIndex].pushes.find(p => p.id === pushId);
        const selectedPrompt = round.prompts[promptIndex];

        if (!selectedPush) return;

        round.pendingSelection = false;
        round.bestPrompt = selectedPrompt;

        state.globalBest = { ...selectedPush, round: state.currentRound };
        state.viewingRoundNum = null;

        $("base-prompt").value = selectedPrompt.text;
        state.basePrompt = selectedPrompt.text;
        autoResizeTextarea($("base-prompt"));
        renderParamFields();

        updateMetrics();
        renderEvolutionBoard();
        renderHistory();
        saveState();

        $("status").textContent = `Round ${state.currentRound} selected. Best: ${selectedPush.score}`;
        log(`[User Selected] Prompt "${selectedPrompt.text.slice(0, 30)}..." with best push score ${selectedPush.score}`, "success");
      }

      function resetAll() {
        state.rounds = [];
        state.currentRound = 0;
        state.globalBest = null;
        state.viewingRoundNum = null;
        state.logs = [];
        log("[System] Reset complete", "");
        renderEvolutionBoard();
        renderHistory();
        updateMetrics();
        saveState();
        $("status").textContent = "Reset. Click Run Next Round.";
      }

      function updateMetrics() {
        $("round-count").textContent = state.rounds.length ? `(${state.rounds.length} rounds)` : "";
        renderHistory();
      }

      function renderHistory() {
        if (!state.rounds.length) {
          $("history-list").innerHTML = '<div class="empty">No history</div>';
          return;
        }

        const bestScore = Math.max(...state.rounds.map(r => r.bestPush?.score || 0));

        $("history-list").innerHTML = [...state.rounds].reverse().map(r => {
          const isBest = (r.bestPush?.score || 0) === bestScore;
          return `
            <button class="history-item ${isBest ? 'best' : ''}" onclick="restoreRound(${r.roundNum})">
              <span class="history-round">Round ${r.roundNum}${isBest ? ' ★' : ''}</span>
              <span class="history-score">${r.bestPush?.score?.toFixed(2) || 'N/A'}</span>
            </button>
          `;
        }).join("");
      }

      function restoreRound(roundNum) {
        const round = state.rounds.find(r => r.roundNum === roundNum);
        if (!round || !round.bestPrompt) return;

        state.basePrompt = round.bestPrompt.text;
        state.viewingRoundNum = roundNum;
        $("base-prompt").value = state.basePrompt;
        autoResizeTextarea($("base-prompt"));
        renderParamFields();
        renderEvolutionBoard();
        renderHistory();
        saveState();

        log(`[System] Viewing Round ${roundNum}: "${round.bestPrompt.text.slice(0, 40)}..."`, "");
        $("status").textContent = `Viewing Round ${roundNum}`;
      }

      function toggleRound(roundNum) {
        const card = document.querySelector(`[data-round="${roundNum}"]`);
        if (card) {
          const content = card.querySelector(".round-content");
          content.classList.toggle("open");
          card.classList.toggle("expanded");
        }
      }

      function toggleTreeCard(card) {
        card.classList.toggle("open");
      }

      function toggleSection(roundNum, section) {
        const card = document.querySelector(`[data-round="${roundNum}"]`);
        if (card) {
          const sec = card.querySelector(`[data-section="${section}"]`);
          if (sec) sec.classList.toggle("open");
        }
      }

      function renderEvolutionBoard() {
        if (!state.rounds.length) {
          $("evolution-board").innerHTML = '<div class="empty">No runs yet. Click "Run Next Round" on the left to start.</div>';
          return;
        }

        let html = '<div class="round-list">';

        const displayRound = state.viewingRoundNum
          ? state.rounds.find(r => r.roundNum === state.viewingRoundNum) || state.rounds[state.rounds.length - 1]
          : state.rounds[state.rounds.length - 1];

        html += `<div class="round-section">`;
        html += `<div class="round-section-header">`;
        html += `<span class="round-title">Round ${displayRound.roundNum}${state.viewingRoundNum ? ' (viewing)' : ''}</span>`;
        html += `<span class="round-best">Best: ${displayRound.bestPush?.score?.toFixed(2) || 'N/A'}</span>`;
        html += `</div>`;

        displayRound.prompts.forEach((prompt, pi) => {
          const isTop = displayRound.topKPrompts && displayRound.topKPrompts.some(p => p.id === prompt.id);
          const isBest = prompt.id === (displayRound.bestPrompt?.id || displayRound.bestPrompt?.bestPush?.id || null);
          const isExpanded = true;
          const isPending = displayRound.pendingSelection;
          const bestPush = prompt.pushes?.[0];

          html += `
            <div class="prompt-tree ${isTop ? 'top' : ''} ${isBest ? 'best' : ''}">
              <div class="prompt-tree-header" onclick="togglePromptTree(this)">
                <span class="prompt-tree-toggle">${isExpanded ? '▼' : '▶'}</span>
                <span class="prompt-tree-name">Prompt #${pi + 1}</span>
                <span class="prompt-tree-score">${bestPush?.score?.toFixed(2) || 'N/A'}</span>
                <button class="optimize-btn" onclick="event.stopPropagation(); showPromptContent(${pi})" style="margin-left:auto;margin-right:4px;">View Full</button>
                <button class="optimize-btn" style="background:#d73a49;color:#fff;border-color:#d73a49;" onclick="event.stopPropagation(); selectPush(${pi}, '${bestPush?.id}')">Best</button>
              </div>
              <div class="prompt-tree-content" style="display: ${isExpanded ? 'block' : 'none'}">
                ${bestPush ? `
                  <div class="push-item best">
                    <div class="push-item-header">
                      <span class="push-item-index">★</span>
                      <span class="push-item-label">Best Push</span>
                      <span class="push-item-score">${typeof bestPush.score === 'number' ? bestPush.score.toFixed(2) : 'N/A'}</span>
                    </div>
                    <div class="push-item-detail">
                      ${bestPush.title ? `<div class="push-item-title" style="font-weight:600;margin-bottom:4px;">${bestPush.title}</div>` : ''}
                      <div class="push-item-text">${bestPush.body || bestPush.text || ''}</div>
                      <div class="push-item-metrics">
                        ${Object.entries(bestPush.metrics || {}).map(([k, v]) => `<span>${k}: ${typeof v === 'number' ? v : v}</span>`).join('')}
                      </div>
                    </div>
                  </div>
                ` : ''}
                ${(prompt.pushes || []).slice(1).map((push, idx) => `
                  <div class="push-item" onclick="togglePushDetail(this)" style="cursor:pointer;">
                    <div class="push-item-header">
                      <span class="push-item-index">├</span>
                      <span class="push-item-label">Push ${idx + 2}</span>
                      <span class="push-item-score">${typeof push.score === 'number' ? push.score.toFixed(2) : 'N/A'}</span>
                    </div>
                    <div class="push-item-detail" style="display:none;">
                      ${push.title ? `<div class="push-item-title" style="font-weight:600;margin-bottom:4px;">${push.title}</div>` : ''}
                      <div class="push-item-text">${push.body || push.text || ''}</div>
                      <div class="push-item-metrics">
                        ${Object.entries(push.metrics || {}).map(([k, v]) => `<span>${k}: ${typeof v === 'number' ? v : v}</span>`).join('')}
                      </div>
                    </div>
                  </div>
                `).join('')}
              </div>
            </div>
          `;
        });

        html += `</div>`;

        html += '</div>';

        $("evolution-board").innerHTML = html;
      }

      function togglePromptTree(el) {
        const tree = el.parentElement;
        const content = tree.querySelector('.prompt-tree-content');
        const toggle = tree.querySelector('.prompt-tree-toggle');
        if (content.style.display === 'none') {
          content.style.display = 'block';
          toggle.textContent = '▼';
        } else {
          content.style.display = 'none';
          toggle.textContent = '▶';
        }
      }

      function togglePushDetail(el) {
        const detail = el.querySelector('.push-item-detail');
        if (detail.style.display === 'none') {
          detail.style.display = 'block';
        } else {
          detail.style.display = 'none';
        }
      }

      function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML.replace(/'/g, "\\'").replace(/"/g, '&quot;');
      }

      function copyPushText(text) {
        const decoded = text.replace(/\\'/g, "'").replace(/&quot;/g, '"');
        navigator.clipboard.writeText(decoded).then(() => {
          log('[System] Copied to clipboard', 'success');
        }).catch(() => {
          log('[System] Copy failed', 'error');
        });
      }

      function showPushDetailModal(pushId, promptIndex) {
        const round = state.rounds[state.rounds.length - 1];
        if (!round || !round.prompts) return;
        const prompt = round.prompts[promptIndex];
        if (!prompt) return;
        const push = prompt.pushes.find(p => p.id === pushId);
        if (!push) return;
        const text = push.body || push.text || '';
        const title = push.title || '';
        showPushDetail(push.id, title, text, push.score, push.metrics);
      }

      function showPromptContent(promptIndex) {
        const round = state.rounds[state.rounds.length - 1];
        if (!round || !round.prompts) return;
        const prompt = round.prompts[promptIndex];
        if (!prompt) return;
        showPromptDetail(prompt.text || '', prompt.bestPush?.score);
      }

      function showPromptDetail(text, score) {
        const modal = $("push-modal");
        const content = $("push-modal-content");
        const escapedText = escapeHtml(text).replace(/\n/g, '<br>');
        content.innerHTML = `
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <span style="font-weight:600;">Prompt Detail</span>
            <span style="cursor:pointer;font-size:18px;color:var(--muted);" onclick="hidePushDetail()">×</span>
          </div>
          <div class="modal-push-text" style="white-space:pre-wrap;line-height:1.6;">${escapedText}</div>
          ${score !== undefined ? `<div class="modal-push-score">Score: ${typeof score === 'number' ? score.toFixed(2) : score}</div>` : ''}
        `;
        modal.classList.add("open");
      }

      function showPushDetail(id, title, text, score, metrics) {
        const modal = $("push-modal");
        const content = $("push-modal-content");
        const metricsHtml = Object.entries(metrics || {}).map(([k, v]) =>
          `<div class="modal-metric"><span>${k}</span><span>${typeof v === 'number' ? v : v}</span></div>`
        ).join("");
        content.innerHTML = `
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
            <span style="font-weight:600;">Push Detail</span>
            <span style="cursor:pointer;font-size:18px;color:var(--muted);" onclick="hidePushDetail()">×</span>
          </div>
          ${title ? `<div class="modal-push-title" style="font-weight:600;font-size:16px;margin-bottom:8px;padding:8px;background:var(--bg);border-radius:6px;">${title}</div>` : ''}
          <div class="modal-push-text">${text}</div>
          <div class="modal-push-score">Score: ${typeof score === 'number' ? score.toFixed(2) : score}</div>
          <div class="modal-push-metrics">${metricsHtml}</div>
        `;
        modal.classList.add("open");
      }

      function hidePushDetail() {
        $("push-modal").classList.remove("open");
      }

      function showTooltip(e, text) {
        const tip = $("tooltip");
        tip.textContent = text;
        tip.style.left = e.pageX + 10 + "px";
        tip.style.top = e.pageY + 10 + "px";
        tip.classList.add("show");
      }

      function hideTooltip() {
        $("tooltip").classList.remove("show");
      }

      // Event Listeners
      $("run-round-btn").addEventListener("click", runNextRound);
      $("reset-btn").addEventListener("click", resetAll);

      function autoResizeTextarea(el) {
        el.style.height = 'auto';
        el.style.height = el.scrollHeight + 'px';
      }

      $("base-prompt").addEventListener("input", e => {
        state.basePrompt = e.target.value;
        renderParamFields();
        autoResizeTextarea(e.target);
      });

      $("strategy").addEventListener("input", e => {
        state.strategy = e.target.value;
        autoResizeTextarea(e.target);
      });

      document.querySelectorAll(".weight-input").forEach(input => {
        input.addEventListener("input", updateWeightSum);
      });

      $("api-key").addEventListener("input", e => { state.runtime.apiKey = e.target.value; });
      $("model-select").addEventListener("change", e => { state.runtime.model = e.target.value; });
      $("api-endpoint").addEventListener("input", e => { state.runtime.endpoint = e.target.value; });

      // Panel Resizer
      const LEFT_PANEL_STORAGE_KEY = "ai_push_left_panel_width";

      function getLeftPanelWidth() {
        const saved = localStorage.getItem(LEFT_PANEL_STORAGE_KEY);
        return saved ? parseInt(saved) : 280;
      }

      function setLeftPanelWidth(width) {
        const clamped = Math.min(450, Math.max(200, width));
        document.documentElement.style.setProperty("--left-width", clamped + "px");
        localStorage.setItem(LEFT_PANEL_STORAGE_KEY, String(clamped));
      }

      let isResizing = false;

      $("panel-resizer").addEventListener("mousedown", e => {
        isResizing = true;
        $("panel-resizer").classList.add("dragging");
        e.preventDefault();
      });

      document.addEventListener("mousemove", e => {
        if (!isResizing) return;
        const newWidth = e.clientX - 16;
        setLeftPanelWidth(newWidth);
      });

      document.addEventListener("mouseup", () => {
        if (isResizing) {
          isResizing = false;
          $("panel-resizer").classList.remove("dragging");
        }
      });

      // Init
      setLeftPanelWidth(getLeftPanelWidth());
      loadState();
      state.basePrompt = $("base-prompt").value;
      state.strategy = $("strategy").value;
      renderParamFields();
      renderEvolutionBoard();
      renderHistory();
      updateMetrics();
      autoResizeTextarea($("base-prompt"));
      autoResizeTextarea($("strategy"));
      log("[System] Initialized", "");
    </script>
  </body>
</html>

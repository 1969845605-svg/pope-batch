        padding: 4px 0;
        font-size: 12px;
      }

      .prev-round-score {
        font-weight: 700;
        color: var(--muted);
      }

      /* Responsive */
      @media (max-width: 1024px) {
        .app { grid-template-columns: 1fr; }
        .panel { max-height: none; }
        .panel.left { border-right: 1px solid var(--line); margin-bottom: 12px; }
        .panel.right { border-left: 1px solid var(--line); margin-top: 12px; }
